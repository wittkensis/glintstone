# Private Files (PLAN/ tree, renamed from PLANNING/)
PLAN/PRIVATE-TODO.md
PLAN/Engineer Onboarding Guide.md
PLAN/PROCESS/
PLAN/PRDs/

# Local harness templates (Eric-only, not for contributors).
# Anchored to repo root: a bare `TEMPLATES/` also matches `app/templates/`
# on case-insensitive filesystems (macOS), which would silently ignore real
# tracked app templates. The leading slash scopes it to the top level only.
/TEMPLATES/

# PRDs (icebox — managed locally, not tracked in git)
PRDs/

# v0.1 app (kept locally for reference)
app-v0.1/

# Source data (re-download via data/tools/)
# SETUP.md at data/sources/ level is tracked; everything else excluded
data/sources/*
!data/sources/SETUP.md

# ML models: sub-repos and large checkpoints
# SETUP.md at ml/models/ level is tracked; sub-repo contents excluded
ml/models/akkademia/
ml/models/deepscribe/
ml/models/ebl_ocr/*
!ml/models/ebl_ocr/SETUP.md

# Bulk source data (re-downloadable; track only manifests and SETUP.md)
source-data/sources/CDLI/
source-data/sources/ORACC/
source-data/sources/eBL/
source-data/sources/ePSD2/
source-data/sources/compvis-annotations
source-data/sources/ebl-annotations
!source-data/sources/SETUP.md
!source-data/sources/*/manifest.json

# Large binary files
*.tar.gz
*.zip
*.pkl
*.pth
*.ckpt
*.h5
*.pt

# CAD digitization working files
data/tools/cad-digitization/pdfs/
data/tools/cad-digitization/output/
data/tools/cad-digitization/logs/

# Import working files — legacy disk-based checkpoints (v1)
# v2 framework records progress in DB tables; these dirs will be archived.
_progress/
data/tools/import/_errors/
data/tools/import/_progress/
source-data/import-tools/_progress/
source-data/import-tools/citations/_cache/
source-data/import-tools/citations/_progress/

# Dead-letter open-count alert status files (#175) — runtime signal written by
# ingestion.dlq_alerts; the directory is tracked (.gitkeep), the JSON snapshots
# are per-run state and must not be committed.
ops/snapshots/dlq-alerts/*.json

# Debug output (committed-by-accident protection)
debug-tablets.json
*.debug.json

# Empty placeholder DB (legacy)
glintstone.db

# Database (generated by import pipeline)
data-model/glintstone.db
data-model/glintstone.db-shm
data-model/glintstone.db-wal

# Runtime state
.pids/
ops/logs/
ops/scripts/.logs/
source-data/checkpoints/

# Deploy: scripts and nginx configs are tracked (needed by GitHub Actions);
# logs and provisioning credentials are not.
ops/deploy/_logs/
ops/deploy/secrets/

# Archive
_archive/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PHP
vendor/

# IDE
.idea/
.vscode/
*.code-workspace
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment — all .env files are local-only; only .env.example is tracked
.env
.env.*
!.env.example

# Temporary
*.tmp

# Docs build output (generated by ops/build_docs.py)
www/docs/

# Local design ideation and mockups (not tracked — use wiki for persistent design docs)
planning/

# Private planning & process material — design specs, research, execution
# artifacts (PRDs/plans/issues), audits, personas, archives. Internal-only:
# kept out of the public repo entirely. Organized under PERSONAL/{design,
# research,execution,archive}/ — see PERSONAL/README.md. Anchored to root.
/PERSONAL/

# Claude Code agent worktrees (created by swarm builds; ephemeral)
.claude/worktrees/
