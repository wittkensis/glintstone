# Glintstone environment configuration
#
# Load order: `.env` first (this file's values are the baseline), then
# `.env.<APP_ENV>` overrides. Copy this file to `.env` for local defaults
# and create `.env.local` / `.env.staging` / `.env.production` for per-env
# overrides. All `.env*` files are gitignored — only `.env.example` is tracked.

APP_ENV=local
APP_DEBUG=true

# === Database ===
# Preferred: single DATABASE_URL (Neon, Railway, Supabase, RDS all emit this).
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Fallback: discrete vars (used only when DATABASE_URL is unset).
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=glintstone
DB_USER=glintstone
DB_PASSWORD=glintstone
# DB_SSLMODE=require  # set when connecting to a hosted DB without DATABASE_URL

# === Service ports (local dev) ===
API_PORT=8001
WEB_PORT=8002
WWW_PORT=8003

# === URLs (used for CORS, links between services) ===
API_URL=http://api.glintstone.test
WEB_URL=http://app.glintstone.test
WWW_URL=http://glintstone.test

# === Object storage (R2) ===
# Backend selector: 'local' (writes under ./var/storage) or 'r2' (Cloudflare R2).
STORAGE_BACKEND=local
# When STORAGE_BACKEND=r2, all four R2_* values are required.
# R2_ACCOUNT_ID=<your Cloudflare account ID>
# R2_ACCESS_KEY_ID=<R2 API token Access Key ID>
# R2_SECRET_ACCESS_KEY=<R2 API token Secret Access Key>
# R2_BUCKET=glintstone-assets
# R2_PUBLIC_BASE_URL=https://cdn.glintstone.org   # optional; falls back to pub-<bucket>.r2.dev

# === CDLI fetch posture ===
# Identifies Glintstone in outbound requests; please keep contact info present.
# CDLI_USER_AGENT="Glintstone/0.1 (academic; +https://app.glintstone.org; contact eric.wittke@gmail.com)"
# Minimum seconds between any two outbound CDLI requests from this process.
# Background backfill additionally honors CDLI_CRAWL_DELAY_SECONDS (robots.txt).
# CDLI_MIN_REQUEST_INTERVAL_SECONDS=5.0
# CDLI_CRAWL_DELAY_SECONDS=60.0

# === Session ===
# Signs the session cookie. The default 'dev-insecure-key' is allowed ONLY when
# APP_ENV is 'local' or 'test'; any other env refuses to boot with it (see #121).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=your-secret-here

# === Deploy target (used by ops/deploy/deploy.sh) ===
# DEPLOY_HOST=your-vps-ip
# DEPLOY_USER=deploy
# DEPLOY_REMOTE_DIR=/var/www/glintstone
